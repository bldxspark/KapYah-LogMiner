{
    "$schema":  "https://schema.tauri.app/config/2",
    "productName":  "KapYah LogMiner",
    "version":  "0.1.1",
    "identifier":  "com.internal.droneloganalyzer",
    "build":  {
                  "beforeDevCommand":  "npm run dev",
                  "beforeBuildCommand":  "npm run build",
                  "devUrl":  "http://127.0.0.1:1420",
                  "frontendDist":  "../dist"
              },
    "app":  {
                "windows":  [
                                {
                                    "title":  "KapYah LogMiner",
                                    "label":  "main",
                                    "width":  1440,
                                    "height":  920,
                                    "minWidth":  1180,
                                    "minHeight":  760,
                                    "resizable":  true
                                }
                            ],
                "security":  {
                                 "csp":  null
                             }
            },
    "bundle":  {
                   "active":  true,
                   "targets":  "all",
                   "icon":  [
                                "icons/icon.ico"
                            ],
                   "resources":  {
                                     "bin/python_backend/":  "python_backend"
                                 },
                   "publisher":  "KapYah Industries Pvt. Ltd.",
                   "homepage":  "https://www.kapyah.com",
                   "copyright":  "KapYah Industries Pvt. Ltd.",
                   "windows":  {
                                   "nsis":  {
                                                "installerIcon":  "icons/icon.ico",
                                                "headerImage":  "installer/nsis-header.bmp",
                                                "sidebarImage":  "installer/nsis-sidebar.bmp",
                                                "startMenuFolder":  "KapYah Industries Pvt. Ltd.",
                                                "displayLanguageSelector":  false
                                            }
                               }
               }
}
